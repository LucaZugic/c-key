{
  "name": "c-key",
  "version": "0.0.1",
  "description": "Smart per-activity rules for Strava, on iOS Shortcuts",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/entry/shortcut.ts --bundle --format=iife --global-name=CKey --target=es2020 --outfile=dist/c-key.js",
    "build:watch": "esbuild src/entry/shortcut.ts --bundle --format=iife --global-name=CKey --target=es2020 --outfile=dist/c-key.js --watch"
  },
  "keywords": [
    "strava",
    "ios",
    "shortcuts",
    "automation",
    "fitness"
  ],
  "author": "Luca Zugic",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
